# ──────────────────────────────────────────────────────────────────────────────
# AmsBot Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# n8n webhook URL — your RAG pipeline endpoint
# Example: https://your-n8n-instance.com/webhook/abc123/chat
N8N_WEBHOOK_URL=https://your-n8n.com/webhook/your-id/chat

# Application display settings
APP_TITLE=AmsBot
APP_SUBTITLE=Gemeente Amsterdam · 24/7 Virtual Assistant

# HTTP request timeout in seconds (increase if n8n RAG is slow to respond)
REQUEST_TIMEOUT_SECONDS=30
